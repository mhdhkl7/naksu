generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Tabel untuk Agenda/Tugas Naksu
model Task {
  id        String   @id @default(uuid())
  title     String
  category  String   
  deadline  String
  isDone    Boolean  @default(false)
  createdAt DateTime @default(now())
}

// Tabel untuk Jadwal Kuliah Haikal
model Course {
  id        String   @id @default(uuid())
  name      String
  sks       Int
  day       Int      // 1=Senin, 2=Selasa, 3=Rabu, 4=Kamis, 5=Jumat
  type      String   // TEORI / PRAKTIK
  lecturer  String
  createdAt DateTime @default(now())
}

// Tabel untuk Agenda/Proker UPM
model UpmProker {
  id        String   @id @default(uuid())
  title     String
  date      String
  status    String   @default("Rencana") // Rencana, Berjalan, Selesai
  createdAt DateTime @default(now())
}

// Tabel untuk Ide & Draf UPM
model UpmIdea {
  id        String   @id @default(uuid())
  title     String
  content   String
  createdAt DateTime @default(now())
}

// --- TABEL KOMTING ---
model Draft {
  id        String   @id @default(cuid())
  content   String   @db.Text
  createdAt DateTime @default(now())
}

model ClassLink {
  id        String   @id @default(cuid())
  title     String
  url       String
  createdAt DateTime @default(now())
}

// --- TABEL PROYEK & PORTOFOLIO ---
model Project {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  tags        String   // Disimpan sebagai teks biasa, dipisah dengan koma
  linkUrl     String
  linkType    String   // Berisi "github" atau "web"
  colorCode   String
  createdAt   DateTime @default(now())
}

// --- TABEL UPM ENGLISH CLUB ---
model UpmMember {
  id        String   @id @default(cuid())
  nim       String   @unique
  name      String
  phone     String?  // Tambahkan ini (tanda ? artinya boleh kosong)
  email     String?  // Tambahkan ini
  joinedAt  DateTime @default(now())
}

model UpmAgenda {
  id          String   @id @default(cuid())
  title       String
  date        String
  description String   @db.Text
  status      String   @default("Upcoming") // Upcoming, Completed
  createdAt   DateTime @default(now())
}